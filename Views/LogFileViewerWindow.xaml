<Window x:Class="DailyWorkJournal.Views.LogFileViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:DailyWorkJournal.ViewModels"
        mc:Ignorable="d"
        Title="Daily Work Journal - Log File Contents"
        Width="800"
        Height="600"
        MinWidth="600"
        MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:LogFileViewerViewModel/>
    </Window.DataContext>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ToolBarTray Grid.Row="0"
                     Margin="0,0,0,10"
                     IsLocked="True"
                     Background="Transparent">
            <ToolBar Background="{StaticResource SurfaceBrush}">
                <Button Command="{Binding CopyAllCommand}"
                        ToolTip="Copy the entire log file contents"
                        Padding="10,5"
                        Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋" Margin="0,0,5,0"/>
                        <TextBlock Text="Copy All"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding RefreshCommand}"
                        ToolTip="Reload the log file from disk"
                        Padding="10,5"
                        Margin="0,0,6,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔄" Margin="0,0,5,0"/>
                        <TextBlock Text="Refresh"/>
                    </StackPanel>
                </Button>

                <Separator/>

                <Button Command="{Binding CloseCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        ToolTip="Close this viewer window"
                        Padding="10,5">
                    <TextBlock Text="Close"/>
                </Button>
            </ToolBar>
        </ToolBarTray>

        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <TextBox Text="{Binding LogFileContent}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="12"
                     Padding="10"
                     BorderThickness="0"
                     Background="Transparent"/>
        </Border>

        <StatusBar Grid.Row="2" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}"
                           TextTrimming="CharacterEllipsis"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
